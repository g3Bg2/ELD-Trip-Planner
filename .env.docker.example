# ─── Compose env file ──────────────────────────────────────
# Copy to .env.docker and fill in real values before running:
#   docker compose --env-file .env.docker up -d --build
# ───────────────────────────────────────────────────────────

# Public host / port
HTTP_PORT=80

# Django
DJANGO_SECRET_KEY=replace-me-with-a-strong-random-string
DJANGO_ALLOWED_HOSTS=your-droplet-ip,your-domain.com,localhost
CORS_ALLOWED_ORIGINS=http://your-droplet-ip,https://your-domain.com

# Postgres
POSTGRES_DB=eld
POSTGRES_USER=eld
POSTGRES_PASSWORD=change-me-strong-random-password

# Frontend build-time API base (same-origin via nginx proxy)
VITE_API_BASE_URL=/api

# External services (free, no key required)
NOMINATIM_URL=https://nominatim.openstreetmap.org
OSRM_URL=https://router.project-osrm.org
APP_USER_AGENT=ELDTripPlanner/1.0

# ─── HTTPS via Caddy (only when using docker-compose.https.yml) ──────
#
# Pick ONE mode:
#
#   A) Let's Encrypt (trusted cert, requires a hostname)
#      No real domain? Use sslip.io which gives you a free wildcard:
#        DOMAIN = <your-droplet-ip-with-dashes>.sslip.io
#        e.g.   203-0-113-42.sslip.io  → resolves to  203.0.113.42
#      CADDYFILE=./Caddyfile
#
#   B) Self-signed (HTTPS on the raw IP, browser shows warning)
#      DOMAIN/CADDY_EMAIL ignored. Just set:
#      CADDYFILE=./Caddyfile.selfsigned
#
DOMAIN=203-0-113-42.sslip.io
CADDY_EMAIL=you@example.com
CADDYFILE=./Caddyfile
