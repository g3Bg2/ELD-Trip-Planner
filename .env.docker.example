# ─── Compose env file ──────────────────────────────────────
# Copy to .env.docker and fill in real values before running:
#   docker compose --env-file .env.docker up -d --build
# ───────────────────────────────────────────────────────────

# Public host / port
HTTP_PORT=80

# Django
DJANGO_SECRET_KEY=replace-me-with-a-strong-random-string
DJANGO_ALLOWED_HOSTS=your-droplet-ip,your-domain.com,localhost
CORS_ALLOWED_ORIGINS=http://your-droplet-ip,https://your-domain.com

# Postgres
POSTGRES_DB=eld
POSTGRES_USER=eld
POSTGRES_PASSWORD=change-me-strong-random-password

# Frontend build-time API base (same-origin via nginx proxy)
VITE_API_BASE_URL=/api

# External services (free, no key required)
NOMINATIM_URL=https://nominatim.openstreetmap.org
OSRM_URL=https://router.project-osrm.org
APP_USER_AGENT=ELDTripPlanner/1.0
